{
  "name": "@rivano/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rivano/core": "workspace:*",
    "@rivano/proxy": "workspace:*",
    "@rivano/observer": "workspace:*",
    "@rivano/engine": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/static": "^8.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
