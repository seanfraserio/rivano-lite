---
import "../styles/global.css";

interface Props {
  title?: string;
  active?: string;
}

const { title = "Rivano Lite", active = "" } = Astro.props;
// Version is displayed in the sidebar — keep in sync with packages/server/src/state.ts
const VERSION = "0.1.0";

const nav = [
  { href: "/", label: "Dashboard", icon: "grid" },
  { href: "/proxy", label: "Proxy", icon: "shield" },
  { href: "/traces", label: "Traces", icon: "activity" },
  { href: "/agents", label: "Agents", icon: "cpu" },
  { href: "/logs", label: "Logs", icon: "terminal" },
  { href: "/settings", label: "Settings", icon: "settings" },
];
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-56 flex-shrink-0 bg-bg-secondary border-r border-border flex flex-col">
      <!-- Logo -->
      <div class="px-4 py-4 border-b border-border-light">
        <div class="flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" class="w-7 h-7">
            <defs>
              <linearGradient id="seg1" x1="50%" y1="0%" x2="50%" y2="100%">
                <stop offset="0%" stop-color="#0EA5E9"/>
                <stop offset="100%" stop-color="#0284C7"/>
              </linearGradient>
              <linearGradient id="seg2" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#06B6D4"/>
                <stop offset="100%" stop-color="#0EA5E9"/>
              </linearGradient>
              <linearGradient id="seg3" x1="100%" y1="100%" x2="0%" y2="0%">
                <stop offset="0%" stop-color="#22D3EE"/>
                <stop offset="100%" stop-color="#06B6D4"/>
              </linearGradient>
            </defs>
            <path d="M60 12 L18 90 L36 90 L60 38 Z" fill="url(#seg1)"/>
            <path d="M22 94 L98 94 L92 106 L28 106 Z" fill="url(#seg2)"/>
            <path d="M60 12 L102 90 L84 90 L60 38 Z" fill="url(#seg3)"/>
          </svg>
          <div>
            <span class="text-base font-semibold text-text-primary">Rivano</span>
            <span class="text-sm text-rivano-400 ml-1">Lite</span>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-2 py-3 space-y-0.5">
        {nav.map(({ href, label, icon }) => {
          const isActive = active === label.toLowerCase() || (active === "" && href === "/");
          return (
            <a
              href={href}
              class:list={[
                "flex items-center gap-2.5 px-3 py-2 rounded-md text-base transition-colors",
                isActive
                  ? "bg-rivano-500/15 text-rivano-300 font-medium"
                  : "text-text-secondary hover:bg-bg-hover hover:text-text-primary",
              ]}
            >
              <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                {icon === "grid" && <path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z" />}
                {icon === "shield" && <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />}
                {icon === "activity" && <path d="M22 12h-4l-3 9L9 3l-3 9H2" />}
                {icon === "cpu" && <><path d="M6 6h12v12H6z" /><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3" /></>}
                {icon === "terminal" && <path d="M4 17l6-5-6-5M12 19h8" />}
                {icon === "settings" && <><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></>}
              </svg>
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Footer -->
      <div class="px-4 py-3 border-t border-border-light">
        <a
          href="https://rivano.ai"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 text-sm text-text-muted hover:text-rivano-400 transition-colors"
        >
          <span>Upgrade to Cloud</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
          </svg>
        </a>
        <p class="text-xs text-text-muted/50 mt-1">v{VERSION}</p>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <slot />
    </main>
  </body>
</html>
